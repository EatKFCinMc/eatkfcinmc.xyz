</html>

<style>
  html {
    min-height: 100%;
    background-image: var(--page-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }
  
  body {
    font-family: system-ui, sans-serif;
    max-width: 1200px;
    margin: 10px auto auto auto;
    padding: 2rem;
  }

  .page-layout {
    display: flex;
  }
  
  .sidebar {
    width: 350px;
    padding: 32px 24px;
    box-sizing: border-box;
  }
  
  .profile-photo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    margin: 0 auto 24px;
    border: 3px solid #ddd;
  }

  .sidebar-text {
    background: #fafafab0;
    border-radius: 25px;
    padding: 0.5rem 1rem 1rem;
  }

  .sidebar-text h2 {
    text-align: center;
    margin: 20px 0;
  }

  .sidebar-text p {
    margin: 8px 0;
    line-height: 1.5;
  }

  .sidebar-text a:link,
  .sidebar-text a:visited,
  .sidebar-text a:active,
  .sidebar-text a:hover {
    text-decoration:none;
    color: #222;
  }
  
  .content {
    min-width: 600px;
    margin: 0 3rem;
    padding: 2rem 3rem;
    line-height: 1.6;
    color: #222;
    background: #fafafab0;
    border-radius: 25px;
  }
  
  header {
    margin-bottom: 2rem;
  }

  .site-title {
    margin-bottom: 0.5rem;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  a {
    color: #2563eb;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  main {
    margin-top: 2rem;
  }

  footer {
    margin-top: 4rem;
    color: #666;
    font-size: 0.9rem;
  }

  
  @media (max-width: 768px) {
    body {
      max-width: none;
      margin: 0;
      padding: 1rem;
    }

    .page-layout {
      flex-direction: column;
      min-height: auto;
    }

    .sidebar {
      width: 100%;
      padding: 1.5rem 1rem;
    }

    .profile-photo {
      width: 110px;
      height: 110px;
      margin-bottom: 1rem;
    }

    .sidebar-text h2 {
      font-size: 1.3rem;
    }

    .sidebar-text p {
      font-size: 0.95rem;
    }

    .content {
      width: 100%;
      flex: none;
      margin: 0;
      padding: 1.5rem;
      box-sizing: border-box;
      border-radius: 18px;
    }

    nav {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .site-title {
      font-size: 1.8rem;
    }
  }
</style>

<script is:inline>
  const backgrounds = [
    "/background/cloud/bg0.jpg",
    "/background/cloud/bg1.jpg",
    "/background/cloud/bg2.jpg",
    "/background/cloud/bg3.JPG",
    "/background/cloud/bg4.JPG",
    "/background/cloud/bg5.JPG",
    "/background/cloud/bg6.JPG",
    "/background/cloud/bg7.JPG",
    "/background/cloud/bg8.JPG",
    "/background/cloud/bg9.JPG",
    "/background/cloud/bg10.JPG",
  ];

  const randomBackground =
      backgrounds[Math.floor(Math.random() * backgrounds.length)];

  document.documentElement.style.setProperty(
      "--page-bg",
      `url("${randomBackground}")`
  );
</script>
        />

        <div class="sidebar-text">
          <h2>EatKFCinMc</h2>
          <p>A normal CS major student</p>
          <p>University: nullptr</p>
          <p>Spec: System and Software</p>
          <p>Pronounce: idgaf</p>
          <p><a href="https://discord.com/users/805337086793089054" target="_blank">Discord: eatkfcinmc</a></p>
          <p>QQ: 2498543792</p>

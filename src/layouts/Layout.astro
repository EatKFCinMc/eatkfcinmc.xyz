---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  
  <body>
    <header>
      <h1 class="site-title">EatKFCinMc's place</h1>

      <nav>
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© 2026 EatKFCinMc</p>
    </footer>

    <script is:inline>
      const backgrounds = [
        "/background/cloud/bg3.JPG",
        "/background/cloud/bg4.JPG",
        "/background/cloud/bg5.JPG",
        "/background/cloud/bg6.JPG",
        "/background/cloud/bg7.JPG",
        "/background/cloud/bg8.JPG",
      ];

      const randomBackground =
          backgrounds[Math.floor(Math.random() * backgrounds.length)];

      document.documentElement.style.setProperty(
          "--page-bg",
          `url("${randomBackground}")`
      );
    </script>
  
  </body>
</html>

<style>
  html {
    min-height: 100%;
    background-image: var(--page-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }
  
  body {
    font-family: system-ui, sans-serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    line-height: 1.6;
    color: #222;
    background: #fafafa;
  }

  header {
    margin-bottom: 2rem;
  }

  .site-title {
    margin-bottom: 0.5rem;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  a {
    color: #2563eb;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  main {
    margin-top: 2rem;
  }

  footer {
    margin-top: 4rem;
    color: #666;
    font-size: 0.9rem;
  }
</style>
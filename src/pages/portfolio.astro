---
import PortfolioLayout from "../layouts/PortfolioLayout.astro";

const projects = [
  {
    title: "Unknown Music Player",
    meta: "Terminal music player",
    description:
      "A TUI-style music player inspired by terminal-first workflows, with ongoing work around playback behavior, interface polish, and Kitty graphics protocol support.",
    links: [
      {
        label: "GitHub",
        href: "https://github.com/EatKFCinMc/Unknown-Music-Player",
      },
    ],
  },
  {
    title: "IdleScreen",
    meta: "Windows utility",
    description:
      "A small desktop utility for manually turning off the display without immediately locking the session, built around a personal workflow need.",
    links: [
      {
        label: "GitHub",
        href: "https://github.com/EatKFCinMc/IdleScreen",
      },
    ],
  },
  {
    title: "eatkfcinmc.xyz",
    meta: "Personal site",
    description:
      "This Astro site: a compact home for project notes, blog posts, experiments, and links.",
    links: [
    ],
  },
];
---

<PortfolioLayout title="Yuhao Wang Portfolio">
  <section class="hero" aria-labelledby="portfolio-title">
    <p class="eyebrow">Software Engineering Portfolio</p>
    <h1 id="portfolio-title">Yuhao Wang</h1>
    <p class="intro">
      CS student focused on systems, backend, security, and embedded-adjacent
      software, with a preference for practical tools and terminal-centered
      interfaces.
    </p>

    <div class="profile-links" aria-label="Profile links">
      <a href="https://github.com/EatKFCinMc" target="_blank">GitHub</a>
      <a href="/">Home</a>
    </div>
  </section>

  <section class="section" aria-labelledby="projects-title">
    <div class="section-heading">
      <p class="eyebrow">Selected Work</p>
      <h2 id="projects-title">Projects</h2>
    </div>

    <div class="project-list">
      {
        projects.map((project) => (
          <article class="project-card">
            <div>
              <p class="project-meta">{project.meta}</p>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </div>

            <div class="project-links">
              {project.links.map((link) => (
                <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined}>
                  {link.label}
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section two-column" aria-label="Skills and interests">
    <div>
      <p class="eyebrow">Focus</p>
      <h2>Engineering Interests</h2>
      <ul>
        <li>Systems and backend software</li>
        <li>Security-minded implementation</li>
        <li>Terminal interfaces and developer tools</li>
        <li>Desktop utilities and low-level debugging</li>
      </ul>
    </div>

    <div>
      <p class="eyebrow">Stack</p>
      <h2>Tools</h2>
      <ul>
        <li>C, C++, Python, JavaScript, TypeScript</li>
        <li>Linux, Windows, shells, Git</li>
        <li>Astro and small web projects</li>
      </ul>
    </div>
  </section>
</PortfolioLayout>

<style>
  .hero {
    padding-bottom: 2rem;
    border-bottom: 1px solid #d8dee6;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: #5b6472;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: break-word;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: 4rem;
    line-height: 1;
  }

  h2 {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.2;
  }

  h3 {
    margin: 0.25rem 0 0.75rem;
    font-size: 1.25rem;
    line-height: 1.25;
  }

  .intro {
    max-width: 720px;
    margin: 1.25rem 0 0;
    color: #3e4754;
    font-size: 1.12rem;
  }

  .profile-links,
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .profile-links {
    margin-top: 1.5rem;
  }

  .profile-links a,
  .project-links a {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.35rem 0.7rem;
    color: #1f2937;
    background: #ffffffb8;
    border: 1px solid #cfd6df;
    border-radius: 8px;
    font-weight: 650;
  }

  .section {
    margin-top: 2.5rem;
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .project-list {
    display: grid;
    gap: 1rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) max-content;
    gap: 1.25rem;
    align-items: start;
    padding: 1.25rem;
    background: #ffffffa8;
    border: 1px solid #d8dee6;
    border-radius: 8px;
  }

  .project-card p {
    margin: 0;
    color: #3e4754;
  }

  .project-meta {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .two-column {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
  }

  ul {
    margin: 1rem 0 0;
    padding-left: 1.2rem;
  }

  li + li {
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.6rem;
    }

    .project-card,
    .two-column {
      grid-template-columns: 1fr;
    }

    .project-links {
      width: 100%;
    }

    .project-links a {
      justify-content: center;
      flex: 1 1 8rem;
    }
  }
</style>
